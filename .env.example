# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# On Vercel: add these under Project → Settings → Environment Variables.

# ── Supabase (public — safe for browser) ──────────────────────────────────────
VITE_SUPABASE_URL=supabase_url
VITE_SUPABASE_ANON_KEY=supabase_anon_key
VITE_SUPABASE_PUBLISHABLE_KEY=supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=project_id

# ── Supabase (server-only — NEVER use VITE_ prefix here) ─────────────────────
SUPABASE_SERVICE_ROLE_KEY=supabase_service_role_key

# ── App URL (for OAuth redirects) ─────────────────────────────────────────────
# Set to your production domain on Vercel, e.g. https://focusflow.app
# Leave empty locally — will fall back to window.location.origin automatically
VITE_APP_URL=

# ── n8n Webhooks ──────────────────────────────────────────────────────────────

VITE_N8N_RERANK_URL=https://priyansh0748.app.n8n.cloud/webhook/focusflow/rerank


# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
VITE_RAZORPAY_KEY_ID=

# ── PostHog (analytics) ───────────────────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="FocusFlow <hello@focusflow.app>"

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
