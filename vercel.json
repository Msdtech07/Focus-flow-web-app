{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/handler.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/handler.js"
    }
  ]
}